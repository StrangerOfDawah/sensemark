{
  "name": "sensemark-extension",
  "version": "1.3.0",
  "private": true,
  "description": "Tests and packaging checks for the Sensemark Chrome extension.",
  "scripts": {
    "check": "node scripts/validate-extension.js",
    "test": "node --test tests/*.test.js",
    "test:coverage": "node --experimental-test-coverage --test-coverage-lines=90 --test-coverage-functions=95 --test-coverage-branches=75 --test-coverage-include=language-detection.js --test-coverage-include=selection-text.js --test-coverage-include=word-response.js --test-coverage-include=text-response.js --test-coverage-include=manual-translation.js --test-coverage-include=ui-scale.js --test tests/*.test.js"
  },
  "devDependencies": {
    "jsdom": "29.1.1"
  },
  "engines": {
    "node": ">=24"
  }
}
